{
  "name": "gtfs-sqljs",
  "version": "0.1.2",
  "description": "Load GTFS data into sql.js SQLite database for querying in browser and Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gtfs",
    "transit",
    "sqlite",
    "sql.js",
    "browser",
    "nodejs"
  ],
  "author": "Théophile Helleboid/SysDevRun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sysdevrun/gtfs-sqljs.git"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "protobufjs": "^8.0.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.1",
    "@types/papaparse": "^5.5.0",
    "@types/sql.js": "^1.4.9",
    "eslint": "^9.39.3",
    "tsup": "^8.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
